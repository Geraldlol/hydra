{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Hydra Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "env": {
        "HYDRA_WORKSPACE_ROOT": "${workspaceFolder}"
      },
      "preLaunchTask": "npm: compile"
    }
  ]
}
